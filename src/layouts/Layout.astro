---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { 
  title, 
  description = "Welcome to my portfolio - A showcase of my work and services"
} = Astro.props;

// Add a version parameter to force favicon refresh
const faviconVersion = "?v=2";
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Christin Sibi - Design & Tinker. Founding product designer portfolio." />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		
		<!-- Favicon with cache busting - Exact Figma design -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=4" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=4" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=4" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=4" />
		<link rel="manifest" href="/site.webmanifest" />
		
		<meta name="generator" content={Astro.generator} />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&family=Roboto+Condensed:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
		
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
  :root {
    --max-width: 1640px;
  }

  .main-container {
    @apply px-4 mx-auto max-w-[var(--max-width)] w-full md:px-[12vw] 3xl:px-[260px];
  }

  .header-container {
    @apply flex flex-col items-center justify-center gap-6 mb-8 w-full mx-auto xl:w-4/5;
  }
</style> 