---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Christin Sibi - Design & Tinker">
	<main class="portfolio-container">
		<div class="portfolio-layout">
			<!-- Header Section -->
			<header class="header-section">
				<h1 class="header-title">CHRISTIN SIBI</h1>
				<div class="header-line"></div>
			</header>
			
			<!-- Main Content Section -->
			<section class="content-section">
				<div class="main-content">
					<h2 class="main-tagline">
						<span class="letter" style="--letter-delay: 0.05s">D</span><span class="letter" style="--letter-delay: 0.1s">e</span><span class="letter" style="--letter-delay: 0.15s">s</span><span class="letter" style="--letter-delay: 0.2s">i</span><span class="letter" style="--letter-delay: 0.25s">g</span><span class="letter" style="--letter-delay: 0.3s">n</span><span class="letter-space-small"> </span><span class="letter" style="--letter-delay: 0.35s">&</span><span class="letter-space-small"> </span><span class="letter" style="--letter-delay: 0.4s">T</span><span class="letter" style="--letter-delay: 0.45s">i</span><span class="letter" style="--letter-delay: 0.5s">n</span><span class="letter" style="--letter-delay: 0.55s">k</span><span class="letter" style="--letter-delay: 0.6s">e</span><span class="letter" style="--letter-delay: 0.65s">r</span><span class="letter" style="--letter-delay: 0.7s">.</span>
					</h2>
					
					<p class="description">
						Founding product designer at <a href="https://ops0.com/" class="link" target="_blank" rel="noopener noreferrer">ops0</a>. Previously UX designer at Eikasia Labs building <a href="https://stoqs.ai/" class="link" target="_blank" rel="noopener noreferrer">Stoqs.ai</a>
					</p>
				</div>
			</section>
			
			<!-- Footer Contact Section -->
			<footer class="footer-section">
				<div class="contact-info">
					<div class="contact-header">
						<span class="contact-label" id="contact-label">Drop a MaIL</span>
					</div>
					<div class="contact-details">
						<button class="copy-icon" id="copy-email-btn" aria-label="Copy email to clipboard" title="Copy email to clipboard">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
								<path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/>
							</svg>
						</button>
						<a href="mailto:christinsibi333@gmail.com" class="email" id="email-address">christinsibi333@gmail.com</a>
					</div>
				</div>
				
				<div class="social-links">
					<a href="https://www.behance.net/christinsibi" class="social-link" aria-label="Behance" target="_blank" rel="noopener noreferrer">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
							<path d="M22 7h-7v-2h7v2zm1.726 10c-.442 1.297-2.029 3-5.101 3-3.074 0-5.564-1.729-5.564-5.675 0-3.91 2.325-5.92 5.466-5.92 3.082 0 4.964 1.782 5.375 4.426.078.506.109 1.188.095 2.14h-8.027c.13 3.211 3.483 3.312 4.588 2.029h3.168zm-7.686-4h4.965c-.105-1.547-1.136-2.219-2.477-2.219-1.466 0-2.277.768-2.488 2.219zm-9.574 6.988h-6.466v-14.967h6.953c5.476.081 5.58 5.444 2.72 6.906 3.461 1.26 3.577 8.061-3.207 8.061zm-3.466-8.988h3.584c2.508 0 2.906-3-.312-3h-3.272v3zm3.391 3h-3.391v3.016h3.341c3.055 0 2.868-3.016.05-3.016z"/>
						</svg>
					</a>
					<a href="https://www.linkedin.com/in/christin-sibi/" class="social-link" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
							<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
						</svg>
					</a>
				</div>
			</footer>
		</div>
	</main>
</Layout>

<script>
	// Copy email functionality
	document.addEventListener('DOMContentLoaded', function() {
		const copyButton = document.getElementById('copy-email-btn');
		const contactLabel = document.getElementById('contact-label');
		const emailAddress = document.getElementById('email-address');
		
		const originalText = 'Drop a MaIL';
		const copiedText = 'Email Copied!';
		const emailToCopy = 'christinsibi333@gmail.com';
		
		let timeoutId = null;
		
		if (copyButton && contactLabel && emailAddress) {
			copyButton.addEventListener('click', async function() {
				try {
					// Copy email to clipboard
					await navigator.clipboard.writeText(emailToCopy);
					
					// Clear any existing timeout
					if (timeoutId) {
						clearTimeout(timeoutId);
					}
					
					// Change text immediately
					contactLabel.textContent = copiedText;
					contactLabel.classList.add('copied');
					copyButton.classList.add('copied');
					
					// Revert back after 3 seconds
					timeoutId = setTimeout(() => {
						contactLabel.textContent = originalText;
						contactLabel.classList.remove('copied');
						copyButton.classList.remove('copied');
						timeoutId = null;
					}, 3000);
					
				} catch (err) {
					// Fallback for browsers that don't support clipboard API
					console.error('Failed to copy email:', err);
					
					// Try the older method
					try {
						const textArea = document.createElement('textarea');
						textArea.value = emailToCopy;
						textArea.style.position = 'fixed';
						textArea.style.left = '-999999px';
						textArea.style.top = '-999999px';
						document.body.appendChild(textArea);
						textArea.focus();
						textArea.select();
						document.execCommand('copy');
						document.body.removeChild(textArea);
						
						// Show success message even with fallback
						if (timeoutId) {
							clearTimeout(timeoutId);
						}
						
						contactLabel.textContent = copiedText;
						contactLabel.classList.add('copied');
						copyButton.classList.add('copied');
						
						timeoutId = setTimeout(() => {
							contactLabel.textContent = originalText;
							contactLabel.classList.remove('copied');
							copyButton.classList.remove('copied');
							timeoutId = null;
						}, 3000);
						
					} catch (fallbackErr) {
						console.error('Fallback copy method also failed:', fallbackErr);
						
						// Show error message briefly
						if (timeoutId) {
							clearTimeout(timeoutId);
						}
						
						contactLabel.textContent = 'Copy Failed';
						contactLabel.classList.add('error');
						
						timeoutId = setTimeout(() => {
							contactLabel.textContent = originalText;
							contactLabel.classList.remove('error');
							timeoutId = null;
						}, 2000);
					}
				}
			});
		}
	});
</script>

<style>
	:root {
		--font-roboto: 'Roboto', Arial, sans-serif;
		--font-roboto-condensed: 'Roboto Condensed', Arial, sans-serif;
		--color-black: #000000;
		--bg-color: #e3e8d0;
	}
	
	/* Ensure fonts are loaded and applied correctly */
	* {
		font-feature-settings: normal;
		font-optical-sizing: auto;
		box-sizing: border-box;
	}
	
	/* Prevent any scrolling and use dynamic viewport for mobile */
	html, body {
		height: 100dvh; /* Use dynamic viewport height to exclude browser UI */
		overflow: hidden;
		margin: 0;
		padding: 0;
	}
	
	.portfolio-container {
		height: 100dvh; /* Dynamic viewport height for mobile */
		width: 100vw;
		background-color: var(--bg-color);
		display: flex;
		align-items: stretch;
		justify-content: center;
		padding: 0;
		overflow: hidden;
		position: fixed;
		top: 0;
		left: 0;
	}
	
	.portfolio-layout {
		width: 100%;
		max-width: 360px; /* Exact mobile width from Figma */
		height: 100dvh;
		background-color: var(--bg-color);
		position: relative;
		overflow: hidden;
	}
	
	/* ============ MOBILE DESIGN - EXACT FIGMA SPECS ============ */
	
	/* Header Section - Mobile (top: 40.165px from Figma) */
	.header-section {
		position: absolute;
		top: 40px; /* Rounded from 40.165px */
		left: 20px; /* 5 * 4px = 20px from Figma */
		width: 320px; /* w-80 = 320px from Figma */
		display: flex;
		flex-direction: column;
		gap: 8px; /* gap-2 = 8px from Figma */
		z-index: 10;
	}
	
	.header-title {
		font-size: 20px; /* Exact from Figma: text-[20px] */
		text-transform: uppercase;
		font-weight: 600; /* font-semibold */
		font-family: var(--font-roboto-condensed);
		color: var(--color-black);
		text-align: left;
		margin: 0;
		line-height: normal; /* leading-[normal] from Figma */
		font-optical-sizing: auto;
		font-style: normal;
		/* Animation */
		opacity: 0;
		transform: translateY(20px);
		filter: blur(8px);
		animation: textIntro 0.8s ease-out 0.1s forwards;
	}
	
	.header-line {
		width: 100%;
		height: 1.6px;
		background-color: var(--color-black);
		opacity: 1;
		/* Animation */
		transform: scaleX(0);
		transform-origin: left;
		animation: lineGrow 0.5s ease-out 0.4s forwards;
	}
	
	/* Main Content Section - Mobile (top: 207.691px from Figma) */
	.content-section {
		position: absolute;
		top: 208px; /* Rounded from 207.691px */
		left: 20px; /* left-5 = 20px from Figma */
		width: 320px; /* w-80 = 320px from Figma */
		z-index: 5;
	}
	
	.main-content {
		display: flex;
		flex-direction: column;
		gap: 16px; /* gap-4 = 16px from Figma code */
		width: 100%;
	}
	
	.main-tagline {
		font-size: 80px; /* Exact from Figma: text-[80px] */
		letter-spacing: -3.2px; /* CORRECTED: Exact from Figma: tracking-[-3.2px] */
		line-height: 82px; /* CORRECTED: Exact from Figma: leading-[82px] */
		font-weight: 500; /* font-medium from Figma */
		font-family: var(--font-roboto);
		color: var(--color-black);
		text-align: left;
		margin: 0;
		font-optical-sizing: auto;
		font-style: normal;
		width: 100%;
		/* Remove main tagline animation as letters will animate individually */
		white-space: nowrap; /* Prevent wrapping on desktop */
	}
	
	.letter {
		display: inline-block;
		opacity: 0;
		transform: translateY(20px);
		filter: blur(8px);
		animation: letterDrop 0.7s ease-out calc(0.3s + var(--letter-delay, 0s)) forwards;
	}
	
	.letter-space-small {
		display: inline-block;
		width: 0.15em; /* Minimal space - half of normal space */
	}
	
	.description {
		font-family: var(--font-roboto);
		font-size: 24px; /* Exact from Figma: text-[24px] */
		font-weight: 400; /* font-normal from Figma */
		color: var(--color-black);
		line-height: 34px; /* Exact from Figma: leading-[34px] */
		margin: 0;
		letter-spacing: -0.48px; /* Exact from Figma: tracking-[-0.48px] */
		font-optical-sizing: auto;
		font-style: normal;
		width: 100%;
		/* Animation */
		opacity: 0;
		transform: translateY(25px);
		filter: blur(8px);
		animation: textIntro 0.8s ease-out 0.6s forwards;
	}
	
	.link {
		color: #0478a3; /* Exact from Figma */
		text-decoration: underline;
		text-decoration-style: solid;
		text-underline-position: from-font; /* Exact from Figma */
		text-decoration-skip-ink: none; /* For Stoqs.ai link */
		font-weight: 400;
		font-family: inherit;
		transition: opacity 0.2s ease;
	}
	
	.link:hover {
		opacity: 0.8;
	}
	
	/* Footer Section - Mobile */
	.footer-section {
		position: absolute;
		bottom: 40px; /* 40px margin from bottom to prevent trimming */
		left: 20px; /* left-5 = 20px from Figma */
		width: 320px; /* w-80 = 320px from Figma */
		display: flex;
		flex-direction: column;
		gap: 24px; /* gap-6 = 24px from Figma */
		align-items: flex-start;
	}
	
	.contact-info {
		display: flex;
		flex-direction: column;
		gap: 8px; /* gap-2 = 8px from Figma */
		width: 100%;
		/* Animation */
		opacity: 0;
		transform: translateY(20px);
		filter: blur(6px);
		animation: textIntro 0.7s ease-out 0.9s forwards;
	}
	
	.contact-header {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 8px; /* gap-2 = 8px from Figma */
		width: 100%;
	}
	
	.contact-label {
		font-family: var(--font-roboto-condensed);
		font-size: 14px; /* Exact from Figma: text-[14px] */
		font-weight: 400; /* font-normal from Figma */
		color: var(--color-black);
		line-height: 20px; /* Exact from Figma: leading-[20px] */
		letter-spacing: 0;
		font-optical-sizing: auto;
		font-style: normal;
		text-transform: uppercase;
		font-stretch: 75%; /* From Figma: 'wdth' 75 */
		transition: color 0.3s ease;
		white-space: nowrap;
	}
	
	.contact-label.copied {
		color: #0478a3;
	}
	
	.contact-label.error {
		color: #d32f2f;
	}
	
	.contact-details {
		display: flex;
		flex-direction: row;
		align-items: flex-start; /* items-start from Figma */
		gap: 8px; /* gap-2 = 8px from Figma */
		width: 100%;
	}
	
	.copy-icon {
		width: 24px; /* size-6 = 24px from Figma */
		height: 24px;
		color: var(--color-black);
		display: flex;
		align-items: center;
		justify-content: center;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0;
		transition: all 0.2s ease;
		border-radius: 4px;
		flex-shrink: 0;
	}
	
	.copy-icon:hover {
		background-color: rgba(0, 0, 0, 0.1);
		transform: scale(1.1);
	}
	
	.copy-icon:active {
		transform: scale(0.95);
	}
	
	.copy-icon.copied {
		color: #0478a3;
		background-color: rgba(4, 120, 163, 0.1);
	}
	
	.copy-icon:focus {
		outline: 2px solid #0478a3;
		outline-offset: 2px;
	}
	
	.email {
		font-family: var(--font-roboto);
		font-size: 18px; /* Exact from Figma: text-[18px] */
		font-weight: 600; /* font-semibold from Figma */
		color: var(--color-black);
		text-decoration: none;
		line-height: 24px; /* Exact from Figma: leading-[24px] */
		letter-spacing: -0.36px; /* Exact from Figma: tracking-[-0.36px] */
		display: block;
		font-optical-sizing: auto;
		font-style: normal;
		transition: text-decoration 0.2s ease;
		white-space: nowrap;
		flex-shrink: 0;
	}
	
	.email:hover {
		text-decoration: underline;
	}
	
	.social-links {
		display: flex;
		align-items: center;
		gap: 24px; /* gap-6 = 24px from Figma */
		justify-content: flex-start;
		/* Animation */
		opacity: 0;
		transform: translateY(15px);
		filter: blur(5px);
		animation: textIntro 0.6s ease-out 1.1s forwards;
	}
	
	.social-link {
		width: 24px; /* size-6 = 24px from Figma */
		height: 24px;
		color: var(--color-black);
		display: flex;
		align-items: center;
		justify-content: center;
		transition: opacity 0.2s ease;
		flex-shrink: 0;
	}
	
	.social-link:hover {
		opacity: 0.7;
	}
	
	.social-link svg {
		width: 100%;
		height: 100%;
	}
	
	/* Mobile responsive adjustments */
	@media (max-width: 480px) {
		.main-tagline {
			white-space: normal; /* Allow wrapping on small screens */
			font-size: 70px; /* Slightly smaller for very small screens */
		}
	}
	
	/* ============ DESKTOP LAYOUT (769px and up) ============ */
	@media (min-width: 769px) {
		/* Use regular viewport height for desktop */
		html, body {
			height: 100vh;
		}
		
		.portfolio-container {
			height: 100vh;
		}
		
		.portfolio-layout {
			max-width: 1440px;
			height: 100vh;
			margin: 0 auto;
		}
		
		/* Header Section - Desktop */
		.header-section {
			position: absolute;
			top: 40px;
			left: 50%;
			transform: translateX(-50%);
			width: calc(100% - 80px);
			max-width: 1152px;
			display: flex;
			flex-direction: column;
			gap: 8px;
			align-items: center;
		}
		
		.header-title {
			text-align: center;
			white-space: nowrap;
		}
		
		/* Main Content Section - Desktop */
		.content-section {
			position: absolute;
			top: 137px;
			left: 50%;
			transform: translateX(-50%);
			width: calc(100% - 80px);
			max-width: 640px;
		}
		
		.main-content {
			gap: 32px;
		}
		
		.main-tagline {
			font-size: 96px;
			letter-spacing: -3.84px;
			line-height: 89px;
			white-space: nowrap; /* Ensure no wrapping on desktop */
		}
		
		/* Footer Section - Desktop */
		.footer-section {
			position: absolute;
			bottom: 40px;
			left: 50%;
			transform: translateX(-50%);
			width: calc(100% - 80px);
			max-width: 640px;
			display: flex;
			flex-direction: row;
			gap: 24px;
			align-items: end;
			justify-content: space-between;
			top: auto;
		}
		
		.contact-info {
			flex-grow: 1;
			width: auto;
		}
		
		.contact-header {
			margin-bottom: 8px;
			width: auto;
		}
		
		.contact-label {
			flex: none;
			white-space: normal;
		}
		
		.contact-details {
			align-items: center;
		}
		
		.email {
			white-space: nowrap;
			width: auto;
		}
		
		.social-links {
			flex-shrink: 0;
			width: auto;
			justify-content: flex-end;
		}
	}
	
	/* Landscape Orientation on Mobile - Use dynamic viewport */
	@media (max-width: 768px) and (orientation: landscape) {
		.footer-section {
			top: 400px; /* Adjust for landscape */
		}
	}
	
	/* ============ ANIMATIONS ============ */
	
	@keyframes textIntro {
		0% {
			opacity: 0;
			transform: translateY(var(--translate-distance, 20px));
			filter: blur(var(--blur-amount, 8px));
		}
		60% {
			opacity: 0.8;
			filter: blur(calc(var(--blur-amount, 8px) * 0.3));
		}
		100% {
			opacity: 1;
			transform: translateY(0);
			filter: blur(0px);
		}
	}
	
	@keyframes letterDrop {
		0% {
			opacity: 0;
			transform: translateY(20px);
			filter: blur(8px);
		}
		50% {
			opacity: 0.7;
			filter: blur(3px);
		}
		100% {
			opacity: 1;
			transform: translateY(0);
			filter: blur(0px);
		}
	}
	
	@keyframes lineGrow {
		0% {
			transform: scaleX(0);
		}
		100% {
			transform: scaleX(1);
		}
	}
	
	/* High DPI Displays */
	@media (-webkit-min-device-pixel-ratio: 2), (min-resolution: 192dpi) {
		.header-line {
			height: 0.8px; /* Adjusted for 1.6px equivalent */
		}
	}
	
	/* Accessibility */
	@media (prefers-reduced-motion: reduce) {
		.header-title,
		.main-tagline,
		.description,
		.contact-info,
		.social-links,
		.header-line,
		.letter {
			animation: none !important;
			opacity: 1 !important;
			transform: none !important;
			filter: none !important;
		}
		
		* {
			transition: none !important;
		}
	}
</style>


